# ── Anthropic (script generation) ────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── HeyGen (avatar video rendering) ──────────────────────────────────────────
HEYGEN_API_KEY=your_heygen_api_key
# Create a Template in HeyGen dashboard with your avatar + voice pre-configured.
# The template should have a text variable named "script" (or edit avatar_video.py
# to match whatever variable name you used). Copy the Template ID here.
HEYGEN_TEMPLATE_ID=your_heygen_template_id

# ── LinkedIn API ──────────────────────────────────────────────────────────────
# OAuth 2.0 credentials from LinkedIn Developer Portal
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret
# Long-lived access token (see docs/linkedin_auth.md for how to get this)
LINKEDIN_ACCESS_TOKEN=your_linkedin_access_token
# Your LinkedIn Person URN (format: urn:li:person:XXXXXXXX)
LINKEDIN_PERSON_URN=urn:li:person:your_id

# ── Scheduler settings ────────────────────────────────────────────────────────
# Cron-style: "HH:MM" daily post time (24h, UTC)
POST_TIME_UTC=09:00
# How many videos to generate per run (1 for daily automation)
VIDEOS_PER_RUN=1

# ── Content settings ──────────────────────────────────────────────────────────
# Niche focus for script generation
CONTENT_NICHE=AI tools, automation, and building with AI
# Your name / persona shown in LinkedIn caption
CREATOR_NAME=Your Name
